{
  "name": "scaffold-toro-app",
  "version": "1.0.0",
  "description": "",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm -F core dev",
    "build": "pnpm -F core build",
    "start": "pnpm -F core start",

    "core:dev": "pnpm -F core dev",
    "core:build": "pnpm -F core build",
    "core:start": "pnpm -F core start",
    "core:lint": "pnpm -F core lint",
    "core:format": "pnpm -F core format",

    "compile": "pnpm -F contracts compile",
    "deploy": "pnpm -F contracts run deploy",

    "contracts:compile": "pnpm -F contracts compile",
    "contracts:deploy": "pnpm -F contracts run deploy",
    "contracts:lint": "pnpm -F contracts lint",
    "contracts:format": "pnpm -F contracts format",
    "contracts:test": "pnpm -F contracts test",

    "lint": "pnpm -F core lint && pnpm -F contracts lint",
    "format": "pnpm -F core format && pnpm -F contracts format",
    "test": "pnpm -F core test && pnpm -F contracts test"
  },
  "packageManager": "pnpm@10.12.4",
  "engines": {
    "node": ">=20.18.3"
  }
}
