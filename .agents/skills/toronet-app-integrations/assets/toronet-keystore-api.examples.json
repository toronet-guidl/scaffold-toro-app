{
  "testnetKeystoreUrl": "https://testnet.toronet.org/api/keystore/",
  "mainnetKeystoreUrl": "https://www.toronet.org/api/keystore/",
  "examples": {
    "signMessage": {
      "method": "POST",
      "url": "https://testnet.toronet.org/api/keystore/",
      "body": {
        "op": "signMessage",
        "params": [
          { "name": "addr", "value": "YOUR_ADDRESS" },
          { "name": "pwd", "value": "YOUR_PASSWORD" },
          { "name": "message", "value": "Today is Monday" }
        ]
      }
    },
    "getMessageSigner": {
      "method": "POST",
      "url": "https://testnet.toronet.org/api/keystore/",
      "body": {
        "op": "getMessageSigner",
        "params": [
          { "name": "message", "value": "Today is Monday" },
          {
            "name": "signedmessage",
            "value": "0xSIGNED_MESSAGE"
          }
        ]
      }
    },
    "callContractFunction": {
      "method": "POST",
      "url": "https://testnet.toronet.org/api/keystore/",
      "body": {
        "op": "callContractFunction",
        "params": [
          { "name": "addr", "value": "YOUR_ADDRESS" },
          { "name": "pwd", "value": "YOUR_PASSWORD" },
          {
            "name": "contractaddress",
            "value": "0xYourContractAddress"
          },
          {
            "name": "functionname",
            "value": "approve"
          },
          {
            "name": "functionarguments",
            "value": "0xSpenderAddress|1000000000000000000"
          },
          {
            "name": "abi",
            "value": "URI_ENCODED_JSON_STRINGIFIED_ABI"
          }
        ]
      }
    }
  }
}